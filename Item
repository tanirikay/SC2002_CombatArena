package sc2002project.items;

import sc2002project.battle.BattleEngine;
import sc2002project.combatants.Combatant;

public abstract class Item {
    private final String name;

    public Item(String name) {
        this.name = name;
    }

    public String getName() {
        return name;
    }

    public abstract void use(Combatant user, Combatant target, BattleEngine engine);
}
